# ==========================================
# MounoWeb Environment Variables Example
# ==========================================

# ------------------------------------------
# Bot Configuration (বট কনফিগারেশন)
# ------------------------------------------
BOT_TOKEN=your_bot_token_here          # টেলিগ্রাম বট টোকেন (প্রয়োজনীয়)
ADMIN_ID=your_telegram_id_here         # অ্যাডমিনের টেলিগ্রাম ইউজার আইডি (প্রয়োজনীয়)
SUPPORT_USERNAME=MdBGC                 # সাপোর্ট ইউজারের টেলিগ্রাম ইউজারনেম
DASHBOARD_TOKEN=                       # অ্যাডমিন ড্যাশবোর্ড অ্যাক্সেস করার টোকেন
FORWARDER_SECRET=                      # ফরওয়ার্ডার অ্যাপের সাথে যোগাযোগের সিক্রেট কী
SCB_FORWARDER_APP_URL=https://github.com/Mouno6969/Mouno-Private/releases/latest/download/scb-forwarder.apk # ফরওয়ার্ডার অ্যাপ ডাউনলোডের লিঙ্ক
SCB_FORWARDER_SERVER_URL=              # ফরওয়ার্ডার সার্ভারের ইউআরএল
TELEGRAM_AUTH_BASE_URL=                # টেলিগ্রাম অথেন্টিকেশন বেইজ ইউআরএল
BACKUP_UPLOAD_URL=                     # ডাটাবেস ব্যাকআপ আপলোড করার ইউআরএল

# ------------------------------------------
# Web Configuration (ওয়েব কনফিগারেশন)
# ------------------------------------------
WEB_SECRET_KEY=your_web_secret_here    # ওয়েব সেশন এবং JWT এনক্রিপশনের জন্য সিক্রেট কী (প্রয়োজনীয়)
DB_PATH=mouno.db                       # ডাটাবেস ফাইলের নাম বা পাথ

# ------------------------------------------
# Crypto Configuration (ক্রিপ্টো কনফিগারেশন)
# ------------------------------------------
SELLER_WALLET_MASTER_KEY=your_master_key # সেলার ওয়ালেট এনক্রিপশন মাস্টার কী (প্রয়োজনীয়)
RATE=137                               # ১ ডলারের বর্তমান রেট (BDT)
STAR_RATE=100                          # ১ টেলিগ্রাম স্টারের রেট (BDT)
LOW_BALANCE_THRESHOLD=1.0              # ব্যালেন্স কতর নিচে নামলে ওয়ার্নিং দিবে

# Networks (প্রাইভেট কী এবং RPC)
SOLANA_KEY=                            # সোলানা প্রাইভেট কী
POLYGON_PRIVATE_KEY=                   # পলিগন (MATIC) প্রাইভেট কী
POLYGON_RPC=                           # পলিগন RPC ইউআরএল (যেমন: Alchemy বা Infura)
BSC_PRIVATE_KEY=                       # বাইন্যান্স স্মার্ট চেইন (BSC) প্রাইভেট কী
BSC_RPC=https://bsc-dataseed.binance.org/ # BSC RPC ইউআরএল
TRON_PRIVATE_KEY=                      # ট্রন (TRC20) প্রাইভেট কী
TON_MNEMONIC=                          # টনের ১২ বা ২৪ শব্দের নেমোনিক (সিফ্রেস)
TON_API_KEY=                           # Toncenter API Key
TON_RPC=https://toncenter.com          # টন RPC ইউআরএল
ETHEREUM_RPC=                          # ইথেরিয়াম RPC ইউআরএল
BASE_RPC=https://mainnet.base.org      # বেইজ নেটওয়ার্ক RPC ইউআরএল
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc # অ্যাভালাঞ্চ RPC ইউআরএল

# Bridges & Swaps
LIFI_API_KEY=                          # LiFi Bridge API Key
RELAY_API_KEY=                         # Relay API Key
SOCKET_API_KEY=                        # Socket API Key

# ------------------------------------------
# AI Configuration (AI কনফিগারেশন)
# ------------------------------------------
AI_PROVIDER_ORDER=cerebras,groq,gemini,nvidia_deepseek,nvidia_kimi,nvidia_gemma,openrouter,mistral,cohere,nvidia_mistral_small,nvidia_llama4_scout,nvidia_nemotron_nano,nvidia_qwen_7b,nvidia_llama_8b,huggingface
CEREBRAS_API_KEY=                      # Cerebras Cloud API Key
NVIDIA_API_KEY=                        # NVIDIA NIM API Key
GEMINI_API_KEY=                        # Google Gemini API Key
GROQ_API_KEY=                          # Groq API Key
OPENROUTER_API_KEY=                    # OpenRouter API Key
HUGGINGFACE_API_KEY=                   # HuggingFace API Key (or HF_TOKEN)
COHERE_API_KEY=                        # Cohere API Key
MISTRAL_API_KEY=                       # Mistral API Key

# ------------------------------------------
# bKash Configuration (বিকাশ কনফিগারেশন)
# ------------------------------------------
BKASH_NUMBER=017XXXXXXXX               # পেমেন্ট রিসিভ করার জন্য বিকাশ নম্বর
